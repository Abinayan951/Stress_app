{
  "expo": {
    "name": "MindEcho",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.emotiondetectai.hz5sar",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Record your voice reflections for stress analysis."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F7F6F2"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.emotiondetectai.hz5sar",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        { "microphonePermission": "Record your voice reflections for stress analysis." }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F7F6F2"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
